{
  "manifest_version": 2,
  "name": "Megatron — Aviator Capture",
  "version": "7.0",
  "description": "Captura multiplicadores do Aviator em tempo real.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "background",
    "webRequest",
    "https://*.spribegaming.com/*",
    "https://*.sortenabet.bet.br/*",
    "https://*.sortebet.bet.br/*",
    "https://*.aposta.bet.br/*",
    "https://*.aviator.com/*",
    "https://aviator-real-time-dashboard.onrender.com/*",
    "https://*.onrender.com/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "browser_action": {
    "default_title": "Megatron Aviator",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.spribegaming.com/*",
        "https://*.sortenabet.bet.br/*",
        "https://*.sortebet.bet.br/*",
        "https://*.aposta.bet.br/*",
        "https://*.aviator.com/*"
      ],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_idle",
      "match_about_blank": true
    }
  ],
  "content_security_policy": "script-src 'self' 'unsafe-eval'; object-src 'self'"
}
