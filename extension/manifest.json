{
  "manifest_version": 2,
  "name": "Megatron Aviator",
  "version": "3.4",
  "description": "Captura rodada e multiplicador do Aviator",
  "permissions": [
    "activeTab",
    "storage",
    "https://aviator-real-time-dashboard.onrender.com/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": [
        "*://*aviator*/*",
        "*://*spribe*/*",
        "*://*casino*/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
