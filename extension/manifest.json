{
  "manifest_version": 2,
  "name": "Megatron Aviator Capture",
  "version": "3.3",
  "description": "Captura multiplicador e rodada do Aviator",
  "permissions": [
    "tabs",
    "activeTab",
    "https://aviator-real-time-dashboard.onrender.com/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
