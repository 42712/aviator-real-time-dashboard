{
  "manifest_version": 2,
  "name": "Megatron — Aviator Capture",
  "version": "4.2",
  "description": "Captura multiplicadores do Aviator em tempo real.",
  "permissions": [
    "activeTab",
    "storage",
    "background",
    "https://*.spribegaming.com/*",
    "https://*.sortenabet.bet.br/*",
    "https://*.aviator.com/*",
    "https://aviator-real-time-dashboard.onrender.com/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.spribegaming.com/*",
        "https://*.sortenabet.bet.br/*",
        "https://*.aviator.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "browser_action": {
    "default_title": "Megatron Aviator",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
