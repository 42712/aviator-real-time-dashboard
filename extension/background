// Megatron — background.js v3.0 (MV2 Kiwi Browser)
var SERVER = "https://aviator-real-time-dashboard.onrender.com";

// Ping a cada 4 min para manter Render acordado
setInterval(function() {
  fetch(SERVER + "/api/ping")
    .then(function(r) { return r.json(); })
    .then(function(d) { console.log("[MEGATRON] Ping OK | online:", d.online); })
    .catch(function() { console.log("[MEGATRON] Servidor dormindo, aguardando..."); });
}, 4 * 60 * 1000);

setInterval(function() {
  console.log("[MEGATRON] Ativo:", new Date().toLocaleTimeString());
}, 30000);

chrome.runtime.onMessage.addListener(function(msg, sender, sendResponse) {
  if (msg.type === "CANDLE") {
    console.log("[MEGATRON] Vela:", msg.multiplier + "x | rodada=" + msg.round);
  }
  sendResponse({ ok: true });
  return true;
});

console.log("[MEGATRON] Background ativo no Kiwi Browser");
