// content.js - Versão otimizada para Kiwi Browser
(function() {
  'use strict';
  
  const SERVER = "https://aviator-real-time-dashboard.onrender.com";
  
  let lastMultiplier = null;
  let sending = false;
  let lastRound = null;
  
  // FUNÇÃO PARA CAPTURAR MULTIPLICADOR
  function getMultiplier() {
    // Seletores específicos para o Aviator
    const elements = document.querySelectorAll(
      'div[class*="multiplier"], span[class*="multiplier"], ' +
      '[class*="coefficient"], .multiplier-value, .paycoeff'
    );
    
    for (let el of elements) {
      let text = el.textContent || el.innerText || '';
      let match = text.match(/(\d+[.,]\d+)/);
      if (match) {
        let val = parseFloat(match[1].replace(',', '.'));
        if (val >= 1.0 && val <= 1000) return val;
      }
    }
    
    // Fallback: qualquer texto com número
    let all = document.querySelectorAll('span, div, p');
    for (let el of all) {
      if (el.children.length) continue;
      let text = el.textContent.trim();
      if (/^\d+[.,]\d{2}x?$/.test(text)) {
        let val = parseFloat(text.replace(/[^0-9.]/g, ''));
        if (val >= 1.0) return val;
      }
    }
    
    return null;
  }
  
  // FUNÇÃO PARA CAPTURAR COR
  function getColor() {
    // Tenta encontrar o elemento do avião
    let plane = document.querySelector(
      '[class*="plane"], [class*="bird"], [class*="rocket"], canvas'
    );
    
    if (plane) {
      let style = window.getComputedStyle(plane);
      return style.backgroundColor || style.color || 'rgba(255,45,120,1)';
    }
    
    return 'rgba(255,45,120,1)'; // cor padrão rosa
  }
  
  // FUNÇÃO PARA CAPTURAR RODADA
  function getRound() {
    // Procura por "Rodada XXXXX"
    let text = document.body.textContent;
    let match = text.match(/[Rr]odada\s*:?\s*(\d+)/) || 
                text.match(/[Rr]ound\s*:?\s*(\d+)/);
    
    if (match) return match[1];
    
    // Procura por número de 6+ dígitos
    let all = document.querySelectorAll('span, div');
    for (let el of all) {
      if (el.children.length) continue;
      let txt = el.textContent.trim();
      if (/^\d{6,}$/.test(txt)) return txt;
    }
    
    return null;
  }
  
  // FUNÇÃO PARA DETECTAR CRASH
  function isCrashed() {
    // Verifica se tem texto de crash
    let text = document.body.textContent;
    if (/flew away|voou|crashed|fim de rodada/i.test(text)) {
      return true;
    }
    
    // Verifica se tem elemento de game over
    if (document.querySelector('[class*="crashed"], [class*="game-over"]')) {
      return true;
    }
    
    return false;
  }
  
  // FUNÇÃO PARA ENVIAR VELA
  async function sendCandle(mult, color, round) {
    if (sending) return;
    if (!mult || mult < 1.01) return;
    
    sending = true;
    
    try {
      let response = await fetch(SERVER + '/api/candle', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          multiplier: parseFloat(mult.toFixed(2)),
          color_rgb: color,
          round: round || 'unknown',
          timestamp: new Date().toISOString()
        })
      });
      
      if (response.ok) {
        console.log('[MEGATRON] ✅ Vela enviada:', mult.toFixed(2) + 'x');
        chrome.runtime.sendMessage({ 
          type: "CANDLE_CAPTURED", 
          data: { multiplier: mult, round: round } 
        });
      }
    } catch (err) {
      console.log('[MEGATRON] Erro ao enviar:', err.message);
    } finally {
      sending = false;
    }
  }
  
  // LOOP PRINCIPAL
  let picoRodada = 0;
  let rodadaEnviada = false;
  let crashed = false;
  
  setInterval(() => {
    let mult = getMultiplier();
    let round = getRound();
    let crashNow = isCrashed();
    
    if (round) lastRound = round;
    if (mult && mult > picoRodada) picoRodada = mult;
    
    // Detecta crash
    if (!crashed && crashNow && !rodadaEnviada) {
      console.log('[MEGATRON] CRASH! Pico:', picoRodada);
      sendCandle(picoRodada, getColor(), round || lastRound);
      rodadaEnviada = true;
      picoRodada = 0;
    }
    
    // Detecta queda brusca (fallback)
    if (!rodadaEnviada && lastMultiplier && lastMultiplier > 1.5 && mult && mult < 1.1) {
      console.log('[MEGATRON] QUEDA! Pico:', picoRodada);
      sendCandle(picoRodada, getColor(), round || lastRound);
      rodadaEnviada = true;
      picoRodada = 0;
    }
    
    // Nova rodada
    if (lastMultiplier && lastMultiplier < 1.1 && mult && mult > 1.5) {
      rodadaEnviada = false;
      picoRodada = 0;
    }
    
    crashed = crashNow;
    lastMultiplier = mult;
    
  }, 800); // Verifica a cada 800ms
  
  console.log('[MEGATRON] Content script carregado');
})();
