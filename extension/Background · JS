// background.js - Versão para extensão (NÃO é o mesmo do servidor)
const SERVER = "https://aviator-real-time-dashboard.onrender.com";

// Ping a cada 2 minutos
setInterval(() => {
  fetch(SERVER + "/api/ping")
    .then(r => r.json())
    .then(d => console.log("[BG] Ping OK"))
    .catch(e => console.log("[BG] Ping falhou"));
}, 120000);

// Mensagens do content script
chrome.runtime.onMessage.addListener((msg, sender, sendResponse) => {
  if (msg.type === "CANDLE_CAPTURED") {
    console.log("[BG] Vela capturada:", msg.data);
    sendResponse({ ok: true });
  }
  return true;
});

console.log("[BG] Megatron background ativo");
