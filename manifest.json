{
  "manifest_version": 3,
  "name": "Megatron Aviator",
  "version": "10.0",
  "description": "Captura multiplicadores do Aviator em tempo real.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://*.spribegaming.com/*",
    "https://aviator-next.spribegaming.com/*",
    "https://launch.spribegaming.com/*",
    "https://*.sortenabet.bet.br/*",
    "https://*.sortebet.bet.br/*",
    "https://*.aposta.bet.br/*",
    "https://*.aviator.com/*",
    "https://aviator-real-time-dashboard-1.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Megatron",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.spribegaming.com/*",
        "https://aviator-next.spribegaming.com/*",
        "https://launch.spribegaming.com/*",
        "https://*.sortenabet.bet.br/*",
        "https://*.sortebet.bet.br/*",
        "https://*.aposta.bet.br/*",
        "https://*.aviator.com/*"
      ],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_start"
    }
  ]
}
